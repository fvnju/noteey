{
  "name": "noteey",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "convex": "^1.33.1",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:realtime": "turbo -F realtime dev",
    "dev:server": "turbo -F @noteey/backend dev",
    "dev:setup": "turbo -F @noteey/backend dev:setup"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^4.20.0",
    "@chenglou/pretext": "^0.0.7",
    "@heroui/react": "^3.0.4",
    "@heroui/styles": "^3.0.4",
    "@noteey/env": "workspace:*",
    "dotenv": "catalog:",
    "jotai": "^2.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@noteey/config": "workspace:*",
    "@types/node": "^24.3.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
